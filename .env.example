# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaExampleKey

# Comma-separated Telegram user IDs allowed to use the bot.
# Get yours by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789

# Optional model overrides (these are the defaults)
#MAIN_MODEL=gemini-2.5-flash-lite
#FALLBACK_MODEL=gemini-2.5-flash
